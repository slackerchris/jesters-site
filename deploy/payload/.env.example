# Public DNS name that points to this VPS
CMS_DOMAIN=cms.example.com

# Email used for Let's Encrypt certificate notices
LETSENCRYPT_EMAIL=you@example.com

# Postgres settings
POSTGRES_DB=payload
POSTGRES_USER=payload
POSTGRES_PASSWORD=replace_with_strong_db_password

# Payload app secret (use a long random value)
PAYLOAD_SECRET=replace_with_long_random_secret

# Backup schedule in cron format (UTC)
# This value means daily at 03:30 UTC
BACKUP_SCHEDULE=30 3 * * *

# Retention policy for backups
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
