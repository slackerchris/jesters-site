---
import type { GetStaticPaths } from 'astro';
import { storeLocations, type StoreLocation } from '../../../config/store';
import LocationTopNav from '../../../components/LocationTopNav.astro';
import Layout from '../../../layouts/Layout.astro';

export const getStaticPaths: GetStaticPaths = async () =>
	storeLocations.map((location) => ({
		params: { location: location.slug },
		props: { locationProfile: location }
	}));

const { locationProfile } = Astro.props as { locationProfile: StoreLocation };
const hasMultipleLocations = storeLocations.length > 1;
const locationBasePath = `/locations/${locationProfile.slug}`;
const servicesDescription = `${locationProfile.name} services in and around ${locationProfile.address.city}.`;
---

<Layout
	title={`Game Lines and Store Services | ${locationProfile.name}`}
	description={servicesDescription}
	canonicalUrl={`${locationProfile.websiteUrl}${locationBasePath}/services`}
	ogImage={`${locationProfile.websiteUrl}/og-store.svg`}
>
	<div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 md:px-10">
		<LocationTopNav
			brand={locationProfile.name}
			basePath={locationBasePath}
			current="services"
			showLocationsLink={hasMultipleLocations}
		/>

		<section class="mt-12">
			<p class="pill-badge">Game Lines and In-Store Focus</p>
			<h1 class="mt-4 text-4xl font-bold md:text-6xl">What you can play, collect, and enjoy at this location</h1>
			<p class="mt-4 max-w-3xl text-sm leading-relaxed text-[var(--text-dim)] md:text-base">
				From TCG staples to hobby-table nights, this page is your quick guide to what the store carries and supports.
			</p>
		</section>

		<section class="mt-10 grid gap-5 md:grid-cols-2">
			{
				locationProfile.services.map((service) => (
					<article class="surface-card rounded-3xl p-6 md:p-7">
						<h2 class="text-2xl font-bold">{service.name}</h2>
						<p class="mt-3 text-sm leading-relaxed text-[var(--text-dim)] md:text-base">{service.description}</p>
					</article>
				))
			}
		</section>

		<section class="mt-12">
			<div class="surface-card p-6 md:p-8">
				<h2 class="text-3xl font-bold">Nearby player communities</h2>
				<div class="mt-5 grid gap-4 md:grid-cols-3">
					{
						locationProfile.serviceAreas.map((area) => (
							<a
								href={`${locationBasePath}/areas/${area.slug}`}
								class="border border-white/15 bg-black/15 px-4 py-4 transition hover:bg-white/10"
							>
								<p class="font-bold">{area.name}</p>
								<p class="mt-2 text-sm text-[var(--text-dim)]">{area.summary}</p>
							</a>
						))
					}
				</div>
			</div>
		</section>
	</div>
</Layout>
