---
import { storeProfile } from '../config/store';
import Layout from '../layouts/Layout.astro';

const servicesDescription = `${storeProfile.name} services in and around ${storeProfile.address.city}.`;
---

<Layout
	title={`Game Lines and Store Services | ${storeProfile.name}`}
	description={servicesDescription}
	canonicalUrl={`${storeProfile.websiteUrl}/services`}
	ogImage={`${storeProfile.websiteUrl}/og-store.svg`}
>
	<div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 md:px-10">
		<header class="reveal-up flex items-center justify-between gap-6">
			<a href="/" class="text-xl font-bold tracking-wide">{storeProfile.name}</a>
			<nav class="flex items-center gap-5 text-sm font-semibold text-[var(--text-dim)]">
				<a href="/" class="transition hover:text-white">Home</a>
				<a href="/community" class="transition hover:text-white">Community</a>
				<a href="/events" class="transition hover:text-white">Events</a>
				<a href="/contact" class="transition hover:text-white">Contact</a>
			</nav>
		</header>

		<section class="mt-12">
			<p class="pill-badge">Game Lines and In-Store Focus</p>
			<h1 class="mt-4 text-4xl font-bold md:text-6xl">What you can play, collect, and enjoy at Jesters</h1>
			<p class="mt-4 max-w-3xl text-sm leading-relaxed text-[var(--text-dim)] md:text-base">
				From TCG staples to hobby-table nights, this page is your quick guide to what the store carries and supports.
			</p>
		</section>

		<section class="mt-10 grid gap-5 md:grid-cols-2">
			{
				storeProfile.services.map((service) => (
					<article class="surface-card rounded-3xl p-6 md:p-7">
						<h2 class="text-2xl font-bold">{service.name}</h2>
						<p class="mt-3 text-sm leading-relaxed text-[var(--text-dim)] md:text-base">{service.description}</p>
					</article>
				))
			}
		</section>

		<section class="mt-12">
			<div class="surface-card p-6 md:p-8">
				<h2 class="text-3xl font-bold">Nearby player communities</h2>
				<div class="mt-5 grid gap-4 md:grid-cols-3">
					{
						storeProfile.serviceAreas.map((area) => (
							<a
								href={`/areas/${area.slug}`}
								class="border border-white/15 bg-black/15 px-4 py-4 transition hover:bg-white/10"
							>
								<p class="font-bold">{area.name}</p>
								<p class="mt-2 text-sm text-[var(--text-dim)]">{area.summary}</p>
							</a>
						))
					}
				</div>
			</div>
		</section>
	</div>
</Layout>
