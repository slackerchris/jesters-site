---
import { storeLocations } from '../config/store';
import Layout from '../layouts/Layout.astro';
import jesterLogo from '../assets/jester.jpg';

const primaryStoreName = storeLocations[0]?.name ?? 'Local Store';
const brandName = primaryStoreName.includes(' - ') ? primaryStoreName.split(' - ')[0] : primaryStoreName;
const hasMultipleLocations = storeLocations.length > 1;
const locationBadge =
	hasMultipleLocations
		? `${storeLocations.length} Locations, One Community`
		: 'One Location, One Community';
const pageDescription = hasMultipleLocations
	? `Choose your nearest ${brandName} location for local events, community updates, and store details.`
	: `Get updates, events, and store details for ${brandName}.`;
const navLabel = hasMultipleLocations ? 'Choose Your Hall' : 'Local Hub';
const heroHeading = hasMultipleLocations
	? 'Choose your location and step into the adventure.'
	: 'Welcome to your local game store hub.';
const heroCopy = hasMultipleLocations
	? 'Each store has its own events, updates, and contact details. Start with your closest location and find your next game night.'
	: 'Find store updates, events, and contact details in one place. Jump in and plan your next visit.';

const selectorSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Store Locations',
	numberOfItems: storeLocations.length,
	itemListElement: storeLocations.map((location, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: location.name,
		url: `${location.websiteUrl}/locations/${location.slug}`
	}))
};
---

<Layout
	title={`Welcome to ${brandName}`}
	description={pageDescription}
>
	<script type="application/ld+json" set:html={JSON.stringify(selectorSchema)}></script>
	<div class="landing-shell mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 md:px-10">
		<div class="guild-atmosphere" aria-hidden="true">
			<span class="orb orb-a"></span>
			<span class="orb orb-b"></span>
			<span class="orb orb-c"></span>
		</div>

		<header class="reveal-up flex items-center justify-between gap-6">
			<p class="text-xl font-bold tracking-wide">{brandName}</p>
			<p class="text-sm font-semibold tracking-[0.14em] text-[var(--text-dim)] uppercase">{navLabel}</p>
		</header>

		<section
			class="guild-hero reveal-up reveal-delay-1 mt-10 md:mt-14"
			style={`--seal-url: url('${jesterLogo.src}')`}
		>
			<p class="pill-badge">{locationBadge}</p>
			<h1 class="guild-title mt-5">{heroHeading}</h1>
			<p class="guild-copy mt-6">{heroCopy}</p>
		</section>

		<section class="reveal-up reveal-delay-2 mt-12">
			<div class="location-list">
				{
					storeLocations.map((location) => (
						<a href={`/locations/${location.slug}`} class="location-row">
							<div>
								<p class={`status-chip ${location.status === 'Open' ? 'status-open' : 'status-soon'}`}>{location.status}</p>
								<h2 class="location-title mt-3">{location.name}</h2>
								<p class="location-summary mt-3">{location.landingSummary}</p>
							</div>
							<div class="location-meta">
								<p class="location-city">{location.address.city}, {location.address.region}</p>
								<p class="location-street">{location.address.streetAddress}</p>
								<p class="location-action">View Location</p>
							</div>
						</a>
					))
				}
			</div>
		</section>
	</div>

	<style>
		.landing-shell {
			position: relative;
			overflow: hidden;
		}

		.landing-shell > :not(.guild-atmosphere) {
			position: relative;
			z-index: 1;
		}

		.guild-atmosphere {
			position: absolute;
			inset: 0;
			pointer-events: none;
			z-index: 0;
		}

		.orb {
			position: absolute;
			border-radius: 999px;
			filter: blur(0.2rem);
		}

		.orb-a {
			top: 6rem;
			left: -3rem;
			width: 16rem;
			height: 16rem;
			background: radial-gradient(circle, rgb(242 95 76 / 25%), transparent 70%);
		}

		.orb-b {
			top: 0;
			right: -2rem;
			width: 14rem;
			height: 14rem;
			background: radial-gradient(circle, rgb(255 209 102 / 24%), transparent 70%);
		}

		.orb-c {
			bottom: 4rem;
			left: 40%;
			width: 18rem;
			height: 18rem;
			background: radial-gradient(circle, rgb(140 230 199 / 16%), transparent 72%);
		}

		.guild-hero {
			position: relative;
			text-align: center;
			max-width: 52rem;
			margin-inline: auto;
			padding-top: 7.25rem;
		}

		.guild-hero::before {
			content: '';
			position: absolute;
			top: -1.9rem;
			left: 50%;
			transform: translateX(-50%);
			width: min(52vw, 16rem);
			height: min(52vw, 16rem);
			background-image: var(--seal-url);
			background-position: center;
			background-repeat: no-repeat;
			background-size: contain;
			opacity: 0.22;
			mix-blend-mode: lighten;
			filter: saturate(0.82) contrast(1.08);
			mask-image: radial-gradient(circle, rgb(0 0 0 / 86%) 48%, transparent 82%);
			pointer-events: none;
			z-index: 0;
		}

		.guild-hero > * {
			position: relative;
			z-index: 1;
		}

		.guild-title {
			font-size: clamp(2.15rem, 6vw, 4.55rem);
			line-height: 1.04;
			letter-spacing: 0.01em;
		}

		.guild-copy {
			max-width: 38rem;
			margin-inline: auto;
			font-size: clamp(1rem, 2.4vw, 1.14rem);
			line-height: 1.68;
			color: var(--text-dim);
		}

		.location-list {
			border-top: 1px solid rgb(255 255 255 / 26%);
			border-bottom: 1px solid rgb(255 255 255 / 22%);
		}

		.location-row {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.25rem;
			padding: 1.4rem 0.25rem;
			border-top: 1px solid rgb(255 255 255 / 10%);
			transition: background-color 200ms ease, transform 200ms ease;
		}

		.location-row:first-child {
			border-top: 0;
		}

		.location-row:hover {
			background: linear-gradient(90deg, rgb(255 255 255 / 6%), rgb(255 255 255 / 0%) 52%);
			transform: translateX(0.2rem);
		}

		.status-chip {
			display: inline-flex;
			font-size: 0.73rem;
			font-weight: 700;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			padding: 0.22rem 0.52rem;
			border: 1px solid rgb(255 255 255 / 25%);
		}

		.status-open {
			color: var(--mint-300);
			border-color: rgb(140 230 199 / 45%);
		}

		.status-soon {
			color: var(--accent-300);
			border-color: rgb(255 209 102 / 40%);
		}

		.location-title {
			font-size: clamp(1.85rem, 3vw, 2.4rem);
			line-height: 1.12;
		}

		.location-summary {
			max-width: 40rem;
			font-size: 0.99rem;
			line-height: 1.62;
			color: var(--text-dim);
		}

		.location-meta {
			display: flex;
			flex-direction: column;
			align-self: center;
			gap: 0.2rem;
		}

		.location-city {
			font-size: 0.94rem;
			font-weight: 700;
		}

		.location-street {
			font-size: 0.75rem;
			color: var(--text-dim);
		}

		.location-action {
			margin-top: 0.48rem;
			font-size: 0.72rem;
			font-weight: 700;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--accent-300);
		}

		@media (min-width: 820px) {
			.location-row {
				grid-template-columns: minmax(0, 1fr) auto;
				align-items: center;
				padding: 1.6rem 0.35rem;
			}

			.location-meta {
				text-align: right;
			}
		}

		:global(html[data-theme='white']) .guild-hero::before {
			opacity: 0.1;
			mix-blend-mode: multiply;
		}

		@media (max-width: 640px) {
			.guild-hero {
				padding-top: 6rem;
			}

			.guild-hero::before {
				top: -1.6rem;
				width: min(68vw, 14rem);
				height: min(68vw, 14rem);
			}
		}
	</style>
</Layout>
