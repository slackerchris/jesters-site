---
import { fullStreetAddress, storeProfile } from '../config/store';
import Layout from '../layouts/Layout.astro';

const dayMap: Record<string, string> = {
	Monday: 'Monday',
	Tuesday: 'Tuesday',
	Wednesday: 'Wednesday',
	Thursday: 'Thursday',
	Friday: 'Friday',
	Saturday: 'Saturday',
	Sunday: 'Sunday'
};

const openingHoursSpecification = storeProfile.openingHours
	.filter((entry) => !entry.closed)
	.map((entry) => ({
		'@type': 'OpeningHoursSpecification',
		dayOfWeek: `https://schema.org/${dayMap[entry.label] ?? entry.label}`,
		opens: entry.opens,
		closes: entry.closes
	}));

const hasPublicRating =
	storeProfile.googleReviewCount > 0 && storeProfile.googleRating > 0;

const ratingStatusLabel = hasPublicRating
	? `${storeProfile.googleRating} (${storeProfile.googleReviewCount} reviews)`
	: 'Not yet rated (0 reviews)';

const reviewsLabel = storeProfile.googleReviewCount === 1 ? 'review' : 'reviews';
const reviewCountLabel = `${storeProfile.googleReviewCount} ${reviewsLabel}`;

const businessSchema = {
	'@context': 'https://schema.org',
	'@type': 'Store',
	name: storeProfile.name,
	url: storeProfile.websiteUrl,
	description: storeProfile.tagline,
	telephone: storeProfile.phone,
	email: storeProfile.email,
	priceRange: storeProfile.priceRange,
	address: {
		'@type': 'PostalAddress',
		streetAddress: storeProfile.address.streetAddress,
		addressLocality: storeProfile.address.city,
		addressRegion: storeProfile.address.region,
		postalCode: storeProfile.address.postalCode,
		addressCountry: storeProfile.address.countryCode
	},
	openingHoursSpecification,
	...(hasPublicRating
		? {
			aggregateRating: {
				'@type': 'AggregateRating',
				ratingValue: storeProfile.googleRating,
				reviewCount: storeProfile.googleReviewCount
			}
		}
		: {}),
	sameAs: [storeProfile.facebookPageUrl, storeProfile.googleMapsPlaceUrl]
};
---

<Layout
	title={`${storeProfile.name} | TCG and Hobby Game Store`}
	description={`${storeProfile.name} in ${storeProfile.address.city}, ${storeProfile.address.region} for TCGs, Warhammer 40K, events, and community play nights.`}
	canonicalUrl={storeProfile.websiteUrl}
	ogImage={`${storeProfile.websiteUrl}/og-store.svg`}
>
	<script type="application/ld+json" set:html={JSON.stringify(businessSchema)}></script>
	<div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 pb-16 pt-8 md:px-10">
		<header class="reveal-up flex items-center justify-between gap-6">
			<a href="/" class="text-xl font-bold tracking-wide">{storeProfile.name}</a>
			<nav class="hidden items-center gap-6 text-sm font-medium text-[var(--text-dim)] md:flex">
				<a href="/services" class="transition hover:text-white">Game Lines</a>
				<a href="/events" class="transition hover:text-white">Events</a>
				<a href="/community" class="transition hover:text-white">Community</a>
				<a href="/contact" class="transition hover:text-white">Visit</a>
			</nav>
		</header>

		<section class="mt-14 grid items-center gap-10 md:mt-20 md:grid-cols-[1.1fr_0.9fr]">
			<div>
				<p class="pill-badge reveal-up reveal-delay-1">Local Hobby Game Store</p>
				<h1 class="reveal-up reveal-delay-2 mt-5 text-5xl leading-[1.05] font-bold md:text-7xl">
					Cards, minis, and community nights in one place.
				</h1>
				<p class="reveal-up reveal-delay-3 mt-6 max-w-xl text-base leading-relaxed text-[var(--text-dim)] md:text-lg">
					{storeProfile.tagline} Follow new drops, upcoming events, and shop updates right here,
					then jump to Facebook for the latest community posts.
				</p>
				<div class="reveal-up reveal-delay-3 mt-8 flex flex-wrap gap-4">
					<a
						href="/community"
						class="rounded-full bg-[var(--accent-500)] px-6 py-3 text-sm font-bold text-white transition hover:translate-y-[-1px] hover:brightness-110"
					>
						See Community Feed
					</a>
					<a
						href="/services"
						class="rounded-full border border-white/30 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Browse Game Lines
					</a>
					<a
						href="/contact"
						class="rounded-full border border-white/30 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Plan Your Visit
					</a>
					<a
						href="/events"
						class="rounded-full border border-white/30 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Upcoming Events
					</a>
				</div>
			</div>

			<div class="surface-card reveal-up reveal-delay-2 p-6 md:p-8">
				<p class="text-sm font-semibold tracking-[0.2em] text-[var(--mint-300)] uppercase">Quick snapshot</p>
				<div class="mt-5 space-y-4">
					<div class="border-b border-white/12 px-0 py-3">
						<p class="text-sm text-[var(--text-dim)]">City</p>
						<p class="mt-1 text-lg font-bold">{storeProfile.address.city}</p>
					</div>
					<div class="border-b border-white/12 px-0 py-3">
						<p class="text-sm text-[var(--text-dim)]">Address</p>
						<p class="mt-1 text-lg font-bold">{fullStreetAddress}</p>
					</div>
					<div class="px-0 py-3">
						<p class="text-sm text-[var(--text-dim)]">Google rating</p>
						<p class="mt-1 text-lg font-bold">{ratingStatusLabel}</p>
					</div>
				</div>
			</div>
		</section>

		<section class="mt-20 grid gap-5 md:grid-cols-2">
			<a href="/services" class="surface-card p-6 transition hover:bg-white/5">
				<p class="text-xs tracking-[0.16em] text-[var(--accent-300)] uppercase">Page 1</p>
				<h2 class="mt-2 text-3xl font-bold">Game Lines and Stock</h2>
				<p class="mt-3 text-sm leading-relaxed text-[var(--text-dim)]">See what games and hobby lines the shop focuses on.</p>
			</a>
			<a href="/events" class="surface-card p-6 transition hover:bg-white/5">
				<p class="text-xs tracking-[0.16em] text-[var(--accent-300)] uppercase">Page 2</p>
				<h2 class="mt-2 text-3xl font-bold">Event Calendar</h2>
				<p class="mt-3 text-sm leading-relaxed text-[var(--text-dim)]">Browse upcoming game nights and event details.</p>
			</a>
			<a href="/community" class="surface-card p-6 transition hover:bg-white/5">
				<p class="text-xs tracking-[0.16em] text-[var(--accent-300)] uppercase">Page 3</p>
				<h2 class="mt-2 text-3xl font-bold">Community and Reviews</h2>
				<p class="mt-3 text-sm leading-relaxed text-[var(--text-dim)]">
					Facebook feed, map, Google rating status, and player FAQ are now on a dedicated page.
				</p>
			</a>
			<a href="/contact" class="surface-card p-6 transition hover:bg-white/5">
				<p class="text-xs tracking-[0.16em] text-[var(--accent-300)] uppercase">Page 4</p>
				<h2 class="mt-2 text-3xl font-bold">Visit and Contact</h2>
				<p class="mt-3 text-sm leading-relaxed text-[var(--text-dim)]">Phone, email, hours, and directions in one place.</p>
			</a>
		</section>

		<section class="mt-14">
			<h2 class="text-2xl font-bold md:text-3xl">Serving local players</h2>
			<div class="mt-5 flex flex-wrap gap-3">
				{storeProfile.serviceAreas.map((area) => (
					<a
						href={`/areas/${area.slug}`}
						class="rounded-full border border-white/30 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						{area.name}
					</a>
				))}
			</div>
			<p class="mt-4 text-sm text-[var(--text-dim)]">
				Rating status: <span class="font-semibold text-white">{ratingStatusLabel}</span> | Reviews: <span class="font-semibold text-white">{reviewCountLabel}</span>
			</p>
		</section>

		<footer class="mt-16 border-t border-white/15 pt-6 text-xs tracking-wide text-[var(--text-dim)] uppercase">
			{storeProfile.name} - your local TCG and hobby game store.
		</footer>
	</div>
</Layout>
