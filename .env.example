# Frontend env
PAYLOAD_API_URL=https://cms.example.com
PAYLOAD_ADMIN_URL=https://cms.example.com/admin

# Shared CMS env
CMS_DOMAIN=cms.example.com
LETSENCRYPT_EMAIL=you@example.com

# Preview env
PREVIEW_PORT=8080

# Payload bind behavior for NPM override
# 127.0.0.1 for same-host NPM, 0.0.0.0 for separate-host NPM
PAYLOAD_BIND_IP=127.0.0.1

# Postgres + Payload secrets
POSTGRES_DB=payload
POSTGRES_USER=payload
POSTGRES_PASSWORD=replace_with_strong_db_password
PAYLOAD_SECRET=replace_with_long_random_secret

# Backup retention
BACKUP_SCHEDULE=30 3 * * *
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
